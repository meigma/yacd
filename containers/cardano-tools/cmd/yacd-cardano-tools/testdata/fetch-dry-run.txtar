# fetch --dry-run prints the resolved download manifest (each file's source URL
# and pin status) without contacting any source. config.json is the single
# pinned anchor for chain artifacts; mainnet additionally pins the Mithril keys.
exec yacd-cardano-tools fetch --profile preview --dry-run
stdout '^profile: preview$'
stdout 'config\.json\thttps://book\.play\.dev\.cardano\.org/environments/preview/config\.json\tsha256:[0-9a-f]{64}'
stdout 'byron-genesis\.json\t.*\tunpinned'
! stderr .

# Mainnet pins the two Mithril verification keys from the Mithril release config.
exec yacd-cardano-tools fetch --profile mainnet --dry-run
stdout 'mithril-genesis\.vkey\thttps://raw\.githubusercontent\.com/.*release-mainnet/genesis\.vkey\tsha256:[0-9a-f]{64}'
stdout 'mithril-ancillary\.vkey\t.*release-mainnet/ancillary\.vkey\tsha256:[0-9a-f]{64}'

# An unknown profile is rejected.
! exec yacd-cardano-tools fetch --profile nope --dry-run
stderr 'unknown profile'
